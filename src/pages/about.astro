---
import Base from '../layouts/Base.astro';
import { statsHTML, teamHTML } from '../lib/render.js';
import { getData } from '../lib/data.js';

const d = await getData();
const fbUrl = d.fbUrl;

const title = 'About Us | Sleaford & Lincolnshire Builders | LME Building Contractors';
const description = 'Reliable local Lincolnshire contractors with 15+ years on the tools. Fully insured and accredited, every build led on-site with a 10-year workmanship guarantee.';
---
<Base title={title} description={description} page="about" ogImage="/assets/img/about-hero.jpg">
  <section class="hero hero-inner">
    <div class="img-slot dark fill"><img src="/assets/img/about-hero.jpg" alt="Two builders in hi-vis shaking hands on site" onload="this.parentNode.classList.add('has-img')" onerror="this.remove()"><span>Drop team / on-site hero photo</span></div>
    <div class="hero-overlay" style="background:linear-gradient(95deg,rgba(8,11,15,0.86) 0%,rgba(8,11,15,0.5) 50%,rgba(8,11,15,0.16) 100%),linear-gradient(0deg,rgba(8,11,15,0.72) 0%,rgba(8,11,15,0) 55%);"></div>
    <div class="wrap hin">
      <span class="eyebrow">About LME</span>
      <h1 class="hero-h1">Meet the Craftsmen Behind LME</h1>
      <p class="hero-isub">Reliable local contractors crafting premium spaces across Lincolnshire — led personally on every site, from first survey to final handover.</p>
      <div class="hero-proof">
        <div class="proof-rating"><span class="stars" style="font-size:15px;">★★★★★</span> <b>4.9/5</b> <span class="muted">· 127 reviews</span></div>
        <span class="proof-chip"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#5cc6e8" stroke-width="2.8" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12.5 L10 17.5 L19 6.5"></path></svg>Fully Insured</span>
        <span class="proof-chip"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#5cc6e8" stroke-width="2.8" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12.5 L10 17.5 L19 6.5"></path></svg>15+ Years</span>
        <span class="proof-chip"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#5cc6e8" stroke-width="2.8" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12.5 L10 17.5 L19 6.5"></path></svg>250+ Projects</span>
      </div>
    </div>
  </section>

  <!-- OUR STORY -->
  <section class="sec tex tex-dots" style="background:#fff;">
    <div class="wrap g-story">
      <div class="reveal">
        <span class="eyebrow" style="margin-bottom:16px;">Who We Are</span>
        <h2 class="h2" style="margin-bottom:20px;">Local builders, premium standards.</h2>
        <p style="font-size:15.5px;line-height:1.78;color:#5b6470;margin:0 0 16px;">We're a Sleaford-based building firm with more than 15 years on the tools across Lincolnshire. From extensions in Lincoln to new builds out towards Grantham, every job is run personally on-site — so you're dealing with the people actually doing the work, not a call centre.</p>
        <p style="font-size:15.5px;line-height:1.78;color:#5b6470;margin:0 0 26px;">We pair modern design with proper, old-fashioned craftsmanship to build spaces that genuinely last, and we'd rather do one job well than rush through three. Most of our work comes through word of mouth and repeat customers — and we'd like to keep it that way.</p>
        <div style="display:flex;gap:14px;flex-wrap:wrap;">
          <a class="btn btn-cy" href="/contact">Start Your Project</a>
          <a class="btn btn-go" href="/projects">See Our Work</a>
        </div>
        <a href={fbUrl} target="_blank" rel="noopener" style="display:inline-flex;align-items:center;gap:8px;margin-top:20px;font-family:'Montserrat',sans-serif;font-weight:700;font-size:14px;color:#1877f2;text-decoration:none;"><svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M24 12.07C24 5.4 18.63 0 12 0S0 5.4 0 12.07c0 6.02 4.39 11.01 10.13 11.93v-8.44H7.08v-3.49h3.05V9.41c0-3.02 1.79-4.69 4.53-4.69 1.31 0 2.69.24 2.69.24v2.97h-1.52c-1.49 0-1.96.93-1.96 1.89v2.26h3.33l-.53 3.49h-2.8v8.44C19.61 23.08 24 18.09 24 12.07Z"/></svg>Follow our latest work on Facebook →</a>
      </div>
      <div class="img-slot r10 reveal r-right" style="width:100%;height:clamp(340px,40vw,480px);"><img src="/assets/img/newbuild.jpg" alt="New build under construction by LME Building Contractors" onload="this.parentNode.classList.add('has-img')" onerror="this.remove()"><span>Drop team / on-site photo</span></div>
    </div>
  </section>

  <!-- WHAT DRIVES US -->
  <section class="sec tex tex-grid" style="background:#f5f4f1;">
    <div class="wrap">
      <div class="reveal" style="text-align:center;max-width:620px;margin:0 auto clamp(40px,5vw,58px);">
        <span class="eyebrow" style="margin-bottom:16px;">What Drives Us</span>
        <h2 class="h2">Built on craftsmanship and trust</h2>
      </div>
      <div class="g-2">
        <div class="box hoverable reveal">
          <div class="box-icon"><svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#1192bb" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"></circle><circle cx="12" cy="12" r="4.5"></circle><circle cx="12" cy="12" r="1"></circle></svg></div>
          <h3 class="box-title">Our Mission</h3>
          <p class="box-text">Crafting premium spaces from concept to completion — and building lasting trust in our community along the way.</p>
        </div>
        <div class="box hoverable reveal">
          <div class="box-icon"><svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#1192bb" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 7l10-4 10 4-10 4z"></path><path d="M2 7v10l10 4 10-4V7"></path><path d="M12 11v10"></path></svg></div>
          <h3 class="box-title">Our Approach</h3>
          <p class="box-text">Modern design meets traditional craftsmanship, with every project led on-site from first survey to final handover.</p>
        </div>
        <div class="box hoverable reveal">
          <div class="box-icon"><svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#1192bb" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="9" r="6"></circle><path d="M8.5 14 7 22l5-3 5 3-1.5-8"></path></svg></div>
          <h3 class="box-title">Quality &amp; Craftsmanship</h3>
          <p class="box-text">Premium materials and meticulous finishing on every build — all backed by our 10-year workmanship guarantee.</p>
        </div>
        <div class="box hoverable reveal">
          <div class="box-icon"><svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#1192bb" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 21s7-6.2 7-11a7 7 0 1 0-14 0c0 4.8 7 11 7 11Z"></path><circle cx="12" cy="10" r="2.4"></circle></svg></div>
          <h3 class="box-title">Local &amp; Reliable</h3>
          <p class="box-text">Lincolnshire-based and proud of it — delivered on time, on budget, with a single accountable point of contact.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- STATS -->
  <section class="sec tex tex-grid" style="background:#f5f4f1;">
    <div class="wrap">
      <div class="reveal" style="text-align:center;max-width:620px;margin:0 auto clamp(42px,5vw,62px);">
        <span class="eyebrow" style="margin-bottom:16px;">By The Numbers</span>
        <h2 class="h2">Our results in numbers</h2>
      </div>
      <div class="g-stats" set:html={statsHTML(d)} />
    </div>
  </section>

  <!-- HOW WE WORK -->
  <section class="sec tex tex-grid" style="background:#f5f4f1;">
    <div class="wrap">
      <div class="reveal" style="text-align:center;max-width:620px;margin:0 auto clamp(40px,5vw,58px);">
        <span class="eyebrow" style="margin-bottom:16px;">How We Work</span>
        <h2 class="h2">A clear, structured process</h2>
      </div>
      <div class="g-4">
        <div class="proc-box reveal"><div class="proc-num">01</div><h3 class="proc-title">Consultation</h3><p class="proc-text">A free, no-obligation site visit to understand your vision, budget and timeline.</p></div>
        <div class="proc-box reveal"><div class="proc-num">02</div><h3 class="proc-title">Design &amp; Quote</h3><p class="proc-text">Detailed design proposals and a clear, itemised quotation with no surprises.</p></div>
        <div class="proc-box reveal"><div class="proc-num">03</div><h3 class="proc-title">Build</h3><p class="proc-text">On-site delivery led personally, with regular updates and rigorous quality control.</p></div>
        <div class="proc-box reveal"><div class="proc-num">04</div><h3 class="proc-title">Handover</h3><p class="proc-text">A finished space, signed off to the highest standard, with aftercare support.</p></div>
      </div>
    </div>
  </section>

  <!-- TEAM -->
  <section class="sec tex tex-dots" style="background:#fff;">
    <div class="wrap">
      <div class="reveal" style="text-align:center;max-width:560px;margin:0 auto clamp(36px,4vw,52px);">
        <span class="eyebrow" style="margin-bottom:16px;">Our People</span>
        <h2 class="h2">Meet the Team</h2>
      </div>
      <div class="g-cards" set:html={teamHTML(d)} />
    </div>
  </section>

  <section style="position:relative;overflow:hidden;background:#12161d;">
    <div class="wrap reveal" style="text-align:center;padding-top:clamp(56px,7vw,88px);padding-bottom:clamp(56px,7vw,88px);max-width:760px;">
      <h2 class="h2" style="color:#fff;margin-bottom:14px;">Let's talk about your project.</h2>
      <p class="lead" style="color:#aab3c0;margin:0 auto 24px;max-width:520px;">A free consultation is the best place to start.</p>
      <a class="btn btn-cy" href="/contact">Get in Touch</a>
    </div>
  </section>
</Base>
