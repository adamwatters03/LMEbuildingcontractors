---
import Base from '../layouts/Base.astro';
import { testimonialsHTML, faqHTML , imgSrc } from '../lib/render.js';
import { getData } from '../lib/data.js';
import { versionFromRequest } from '../lib/preview.js';

const d = await getData(versionFromRequest(Astro));
const p = d.pages.contact;
const fbUrl = d.fbUrl;
const title = 'Contact Us | Free Quote in Lincolnshire | LME Building Contractors';
const description = 'Get a free, no-obligation quote within one working day. Extensions, renovations and new builds across Lincolnshire. Call LME Building Contractors on 07592 278032.';
---
<Base title={title} description={description} page="contact" ogImage="/assets/img/contact-hero.jpg" includeFaq={true}>
  <section class="hero hero-inner">
    <div class="img-slot dark fill"><img src={imgSrc(p.heroImage)} alt="Handshake over building plans with hard hat" onload="this.parentNode.classList.add('has-img')" onerror="this.remove()"><span>Drop handshake / team hero photo</span></div>
    <div class="hero-overlay" style="background:linear-gradient(95deg,rgba(8,11,15,0.86) 0%,rgba(8,11,15,0.5) 50%,rgba(8,11,15,0.16) 100%),linear-gradient(0deg,rgba(8,11,15,0.72) 0%,rgba(8,11,15,0) 55%);"></div>
    <div class="wrap hin">
      <span class="eyebrow" data-sb="heroEyebrow">{p.heroEyebrow}</span>
      <h1 class="hero-h1">{p.heroTitle}</h1>
      <p class="hero-isub" data-sb="heroSub">{p.heroSub}</p>
      <div class="hero-proof">
        <div class="proof-rating"><span class="stars" style="font-size:15px;">★★★★★</span> <b>4.9/5</b> <span class="muted">· 127 reviews</span></div>
        <span class="proof-chip"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#5cc6e8" stroke-width="2.8" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12.5 L10 17.5 L19 6.5"></path></svg>Reply in 1 Working Day</span>
        <span class="proof-chip"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#5cc6e8" stroke-width="2.8" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12.5 L10 17.5 L19 6.5"></path></svg>Free Consultation</span>
        <span class="proof-chip"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#5cc6e8" stroke-width="2.8" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12.5 L10 17.5 L19 6.5"></path></svg>No Obligation</span>
      </div>
    </div>
  </section>

  <!-- CONTACT: FORM + METHODS -->
  <section class="sec tex tex-grid" style="background:#f5f4f1;">
    <div class="wrap g-contact">
      <!-- LEFT: FORM CARD -->
      <div class="box reveal" style="padding:clamp(26px,3vw,42px);">
        <h2 style="font-family:'Montserrat',sans-serif;font-weight:800;font-size:clamp(23px,2.6vw,30px);margin:0 0 10px;color:#15191f;letter-spacing:-.4px;" data-sb="formHeading">{p.formHeading}</h2>
        <p style="font-size:15px;color:#5b6470;margin:0 0 30px;line-height:1.65;" data-sb="formIntro">{p.formIntro}</p>
        <div id="contact-thanks" style="display:none;background:#eaf7fc;border:1px solid #33b8de;border-radius:12px;padding:40px;text-align:center;">
          <div style="font-family:'Montserrat',sans-serif;font-weight:800;font-size:24px;color:#1192bb;margin-bottom:10px;">Thanks — that's on its way!</div>
          <p style="font-size:15px;color:#3a414c;margin:0;">We've got your details and we'll be in touch within one working day. If it's urgent, give us a ring on <a href="tel:07592278032" style="color:#1192bb;font-weight:600;">07592 278032</a>.</p>
        </div>
        <form id="contact-form">
          <div class="fgrid">
            <div class="fld"><label>Your name <span class="req">*</span></label><input type="text" name="name" required placeholder="e.g. Sarah Jones" class="field"></div>
            <div class="fld"><label>Email address <span class="req">*</span></label><input type="email" name="email" required placeholder="you@example.com" class="field"></div>
          </div>
          <div class="fgrid">
            <div class="fld"><label>Phone number <span class="req">*</span></label><input type="tel" name="phone" required placeholder="07000 000000" class="field"></div>
            <div class="fld"><label>Project location / town</label><input type="text" name="location" placeholder="e.g. Sleaford" class="field"></div>
          </div>
          <div class="fgrid">
            <div class="fld"><label>Type of project</label>
              <select name="type" class="field">
                <option value="">Please choose…</option>
                <option>Home extension</option>
                <option>Loft conversion</option>
                <option>Garage conversion</option>
                <option>Renovation / refurbishment</option>
                <option>New build</option>
                <option>Garden room / outbuilding</option>
                <option>Something else</option>
              </select>
            </div>
            <div class="fld"><label>Size of project</label>
              <select name="size" class="field">
                <option value="">Please choose…</option>
                <option>Single room</option>
                <option>Single-storey extension</option>
                <option>Two-storey / large extension</option>
                <option>Whole house / new build</option>
                <option>Not sure yet</option>
              </select>
            </div>
          </div>
          <div class="fgrid">
            <div class="fld"><label>Approximate budget</label>
              <select name="budget" class="field">
                <option value="">Please choose…</option>
                <option>Under £25,000</option>
                <option>£25,000 – £50,000</option>
                <option>£50,000 – £100,000</option>
                <option>£100,000+</option>
                <option>Not sure yet</option>
              </select>
            </div>
            <div class="fld"><label>Preferred time for a quote</label>
              <select name="time" class="field">
                <option value="">Please choose…</option>
                <option>Morning (8am – 12pm)</option>
                <option>Afternoon (12pm – 5pm)</option>
                <option>Evening (after 5pm)</option>
                <option>Weekend</option>
                <option>Any time</option>
              </select>
            </div>
          </div>
          <div class="fld"><label>Preferred date for a quote</label><input type="date" name="date" class="field"></div>
          <div class="fld"><label>Tell us about your project</label><textarea name="message" rows="5" placeholder="A few details on what you're planning — rough timescales, must-haves, anything we should know." class="field"></textarea></div>
          <button type="submit" class="btn btn-cy" style="padding:17px;width:100%;">Send My Enquiry</button>
          <p style="font-size:12.5px;color:#9aa2ac;margin:14px 0 0;text-align:center;">No obligation, and we'll never share your details. See our <a href="/privacy" style="color:#1192bb;">Privacy Policy</a>.</p>
        </form>
      </div>

      <!-- RIGHT: CONTACT METHODS CARD -->
      <div class="reveal"><div class="box" style="padding:clamp(24px,2.6vw,34px);"><div class="contact-methods">
        <div class="cm-item">
          <div class="cm-ico"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#1192bb" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92Z"></path></svg></div>
          <div>
            <h3 class="cm-h" data-sb="callTitle">{p.callTitle}</h3>
            <p class="cm-p" data-sb="callText">{p.callText}</p>
            <a class="cm-link" href={d.phoneHref}>{d.phone}</a>
          </div>
        </div>
        <div class="cm-item">
          <div class="cm-ico"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#1192bb" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"></rect><path d="m2 7 10 6 10-6"></path></svg></div>
          <div>
            <h3 class="cm-h" data-sb="emailTitle">{p.emailTitle}</h3>
            <p class="cm-p" data-sb="emailText">{p.emailText}</p>
            <a class="cm-link" href={'mailto:' + d.email}>{d.email}</a>
          </div>
        </div>
        <div class="cm-item">
          <div class="cm-ico"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#1192bb" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 21s7-6.2 7-11a7 7 0 1 0-14 0c0 4.8 7 11 7 11Z"></path><circle cx="12" cy="10" r="2.4"></circle></svg></div>
          <div>
            <h3 class="cm-h" data-sb="whereTitle">{p.whereTitle}</h3>
            <p class="cm-p" data-sb="whereText">{p.whereText}</p>
            <div style="font-size:14px;color:#3a414c;font-weight:600;line-height:1.6;" data-sb="whereTowns">{p.whereTowns}</div>
          </div>
        </div>
        <div class="cm-item">
          <div class="cm-ico"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#1192bb" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"></circle><path d="M12 7v5l3 2"></path></svg></div>
          <div>
            <h3 class="cm-h" data-sb="hoursTitle">{p.hoursTitle}</h3>
            <p class="cm-p" style="margin-bottom:0;" data-sb="hoursText" set:html={p.hoursText}></p>
          </div>
        </div>
        <div class="cm-item">
          <div class="cm-ico"><svg width="22" height="22" viewBox="0 0 24 24" fill="#1192bb" aria-hidden="true"><path d="M24 12.07C24 5.4 18.63 0 12 0S0 5.4 0 12.07c0 6.02 4.39 11.01 10.13 11.93v-8.44H7.08v-3.49h3.05V9.41c0-3.02 1.79-4.69 4.53-4.69 1.31 0 2.69.24 2.69.24v2.97h-1.52c-1.49 0-1.96.93-1.96 1.89v2.26h3.33l-.53 3.49h-2.8v8.44C19.61 23.08 24 18.09 24 12.07Z"/></svg></div>
          <div>
            <h3 class="cm-h" data-sb="followTitle">{p.followTitle}</h3>
            <p class="cm-p" data-sb="followText">{p.followText}</p>
            <a class="cm-link" href={fbUrl} target="_blank" rel="noopener">Find us on Facebook</a>
          </div>
        </div>
      </div></div></div>
    </div>
    <!-- MAP -->
    <div class="wrap" style="margin-top:clamp(22px,2.8vw,32px);">
      <div class="box reveal" style="padding:10px;overflow:hidden;">
        <iframe class="map-embed" title="LME Building Contractors service area — Sleaford, Lincolnshire" src="https://www.google.com/maps?q=Sleaford,Lincolnshire,UK&z=10&output=embed" loading="lazy" referrerpolicy="no-referrer-when-downgrade" style="height:clamp(280px,40vh,420px);border-radius:12px;"></iframe>
      </div>
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <section class="sec" style="background:#fff;">
    <div class="wrap">
      <div class="reveal" style="text-align:center;max-width:640px;margin:0 auto clamp(38px,5vw,56px);">
        <span class="eyebrow" style="margin-bottom:16px;" data-sb="testimonialsEyebrow">{p.testimonialsEyebrow}</span>
        <h2 class="h2" style="margin-bottom:16px;" data-sb="testimonialsHeading">{p.testimonialsHeading}</h2>
        <div class="stars" style="font-size:22px;">★★★★★</div>
      </div>
      <div class="g-cards" set:html={testimonialsHTML(d)} />
    </div>
  </section>

  <!-- FAQ -->
  <section class="sec tex tex-grid" style="background:#f5f4f1;">
    <div class="wrap">
      <div class="reveal" style="text-align:center;max-width:600px;margin:0 auto clamp(36px,4vw,52px);">
        <span class="eyebrow" style="margin-bottom:16px;" data-sb="faqEyebrow">{p.faqEyebrow}</span>
        <h2 class="h2" data-sb="faqHeading">{p.faqHeading}</h2>
      </div>
      <div class="reveal" style="max-width:840px;margin:0 auto;" set:html={faqHTML(d)} />
    </div>
  </section>
</Base>
