---
import Base from '../layouts/Base.astro';
import { getData } from '../lib/data.js';
import { versionFromRequest } from '../lib/preview.js';
import {
  statsHTML, homeServicesHTML, valuePropsHTML, featuredHTML, galleryHTML,
  processHTML, testimonialsHTML, accHTML, homeBlogHTML, imgSrc,
} from '../lib/render.js';

const d = await getData(versionFromRequest(Astro));
const p = d.pages.home;
const areaChips = d.areaChips;
const fbUrl = d.fbUrl;
const flags = d.flags || {};
const title = 'Builders in Sleaford & Lincolnshire | LME Building Contractors';
const description = 'Sleaford-based builders covering Lincoln, Grantham, Boston & across Lincolnshire. Home extensions, renovations & new builds — fully insured, 10-yr guarantee, free quotes.';
---
<Base title={title} description={description} page="home" includeFaq={true}>
  <!-- HERO -->
  <section class="hero hero-home">
    <div class="img-slot dark fill"><img src={imgSrc(p.heroImage)} alt="Builder reviewing plans inside a timber-framed new build" onload="this.parentNode.classList.add('has-img')" onerror="this.remove()"><span>Drop hero build photo</span></div>
    <div class="hero-overlay" style="background:linear-gradient(95deg,rgba(8,11,15,0.88) 0%,rgba(8,11,15,0.52) 46%,rgba(8,11,15,0.12) 100%),linear-gradient(0deg,rgba(8,11,15,0.72) 0%,rgba(8,11,15,0) 55%);"></div>
    <div class="wrap hin">
      <div class="hero-grid">
        <div class="hero-copy">
          <p class="hero-eyebrow" data-sb="heroEyebrow">{p.heroEyebrow}</p>
          <h1 class="hero-title"><span data-sb="heroTitle">{p.heroTitle}</span> <span class="cy" data-sb="heroTitleHighlight">{p.heroTitleHighlight}</span></h1>
          <p class="hero-sub" data-sb="heroSub">{p.heroSub}</p>
          <div class="hero-cta">
            <a class="btn btn-cy" href="/contact" data-sb="heroCtaPrimary">{p.heroCtaPrimary}</a>
            <a class="btn btn-gl" href="/projects" data-sb="heroCtaSecondary">{p.heroCtaSecondary}</a>
          </div>
        </div>
        <div class="hero-form-card">
          <h2 data-sb="formHeading">{p.formHeading}</h2>
          <p class="hfc-sub" data-sb="formSub">{p.formSub}</p>
          <div id="hero-thanks" style="display:none;background:#eaf7fc;border:1px solid #33b8de;border-radius:12px;padding:26px;text-align:center;">
            <div style="font-family:'Montserrat',sans-serif;font-weight:800;font-size:19px;color:#1192bb;margin-bottom:8px;">Thanks!</div>
            <p style="font-size:14px;color:#3a414c;margin:0;">We've got your details and we'll be in touch shortly.</p>
          </div>
          <form id="hero-form">
            <input type="text" name="name" required placeholder="Your name" class="field">
            <input type="text" name="contact" required placeholder="Phone or email" class="field">
            <select name="type" class="field">
              <option value="">What's the project?</option>
              <option>Home extension</option>
              <option>Loft conversion</option>
              <option>Garage conversion</option>
              <option>Renovation / refurbishment</option>
              <option>New build</option>
              <option>Something else</option>
            </select>
            <button type="submit" class="btn btn-cy" style="width:100%;" data-sb="formButton">{p.formButton}</button>
          </form>
          <p class="hfc-foot">Prefer to talk? Call <a href={d.phoneHref}>{d.phone}</a></p>
        </div>
      </div>
      <div class="hero-trustbar">
        {flags.showReviews && <div class="t-item"><span class="stars" style="font-size:14px;">★★★★★</span>&nbsp;4.9 / 5 · 127 reviews</div>}
        <div class="t-item"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#5cc6e8" stroke-width="2.8" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12.5 L10 17.5 L19 6.5"></path></svg>Fully Insured</div>
        <div class="t-item"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#5cc6e8" stroke-width="2.8" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12.5 L10 17.5 L19 6.5"></path></svg>15+ Years</div>
        <div class="t-item"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#5cc6e8" stroke-width="2.8" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12.5 L10 17.5 L19 6.5"></path></svg>10-Year Guarantee</div>
      </div>
    </div>
  </section>

  <!-- OFFER BANNER -->
  {flags.showOffer && (
  <section style="background:#1192bb;">
    <div class="wrap split" style="padding-top:18px;padding-bottom:18px;">
      <div style="display:flex;align-items:center;gap:16px;flex-wrap:wrap;">
        <span style="font-family:'Montserrat',sans-serif;font-weight:800;font-size:11px;letter-spacing:1.6px;color:#06343f;background:#bdeafa;padding:6px 12px;border-radius:5px;" data-sb="offerBadge">{p.offerBadge}</span>
        <span style="font-family:'Montserrat',sans-serif;font-weight:600;font-size:clamp(15px,1.4vw,18px);color:#fff;" data-sb="offerText" set:html={p.offerText}></span>
      </div>
      <a class="btn" href="/contact" style="background:#fff;color:#0c3d4c;padding:12px 22px;font-size:14px;" data-sb="offerButton">{p.offerButton}</a>
    </div>
  </section>
  )}

  <!-- STATS -->
  <section class="sec tex tex-grid" style="background:#f5f4f1;">
    <div class="wrap">
      <div class="reveal" style="text-align:center;max-width:620px;margin:0 auto clamp(42px,5vw,62px);">
        <span class="eyebrow" style="margin-bottom:16px;" data-sb="statsEyebrow">{p.statsEyebrow}</span>
        <h2 class="h2" data-sb="statsHeading">{p.statsHeading}</h2>
      </div>
      <div class="g-stats" set:html={statsHTML(d)} />
    </div>
  </section>

  <!-- SERVICES -->
  <section class="sec tex tex-grid" style="background:#f5f4f1;">
    <div class="wrap">
      <div class="reveal" style="max-width:680px;margin-bottom:clamp(38px,5vw,58px);">
        <span class="eyebrow" style="margin-bottom:16px;" data-sb="servicesEyebrow">{p.servicesEyebrow}</span>
        <h2 class="h2" style="margin-bottom:16px;" data-sb="servicesHeading">{p.servicesHeading}</h2>
        <p class="lead" data-sb="servicesLead">{p.servicesLead}</p>
      </div>
      <div class="g-cards" set:html={homeServicesHTML(d)} />
    </div>
  </section>

  <!-- WHY US -->
  <section class="sec tex tex-dots" style="background:#fff;">
    <div class="wrap">
      <div class="reveal" style="text-align:center;max-width:640px;margin:0 auto clamp(38px,5vw,56px);">
        <span class="eyebrow" style="margin-bottom:16px;" data-sb="whyEyebrow">{p.whyEyebrow}</span>
        <h2 class="h2" data-sb="whyHeading">{p.whyHeading}</h2>
      </div>
      <div class="g-4" set:html={valuePropsHTML(d)} />
    </div>
  </section>

  <!-- FEATURED PROJECTS -->
  <section class="sec tex tex-grid" style="background:#f5f4f1;">
    <div class="wrap">
      <div class="reveal split" style="margin-bottom:clamp(36px,4vw,52px);align-items:flex-end;">
        <div>
          <span class="eyebrow" style="margin-bottom:16px;" data-sb="featuredEyebrow">{p.featuredEyebrow}</span>
          <h2 class="h2" data-sb="featuredHeading">{p.featuredHeading}</h2>
        </div>
        <a class="btn btn-go" href="/projects" style="padding:14px 24px;font-size:14px;">All Projects →</a>
      </div>
      <div class="g-cards" set:html={featuredHTML(d)} />
    </div>
  </section>

  <!-- GALLERY -->
  <section class="sec tex tex-dots" style="background:#fff;">
    <div class="wrap">
      <div class="reveal" style="text-align:center;max-width:600px;margin:0 auto clamp(32px,4vw,46px);">
        <span class="eyebrow" style="margin-bottom:16px;" data-sb="galleryEyebrow">{p.galleryEyebrow}</span>
        <h2 class="h2" data-sb="galleryHeading">{p.galleryHeading}</h2>
      </div>
      <div class="g-gallery reveal" set:html={galleryHTML(d)} />
    </div>
  </section>

  <!-- PROCESS -->
  <section class="sec tex tex-grid-d" style="background:#12161d;">
    <div class="wrap">
      <div class="reveal" style="max-width:600px;margin-bottom:clamp(38px,5vw,58px);">
        <span class="eyebrow" style="color:#5cc6e8;margin-bottom:16px;" data-sb="processEyebrow">{p.processEyebrow}</span>
        <h2 class="h2" style="color:#fff;" data-sb="processHeading">{p.processHeading}</h2>
      </div>
      <div class="g-4" set:html={processHTML(d)} />
    </div>
  </section>

  <!-- TESTIMONIALS -->
  {flags.showReviews && (
  <section class="sec tex tex-grid" style="background:#f5f4f1;">
    <div class="wrap">
      <div class="reveal" style="text-align:center;max-width:640px;margin:0 auto clamp(38px,5vw,56px);">
        <span class="eyebrow" style="margin-bottom:16px;" data-sb="testimonialsEyebrow">{p.testimonialsEyebrow}</span>
        <h2 class="h2" style="margin-bottom:16px;" data-sb="testimonialsHeading">{p.testimonialsHeading}</h2>
        <div class="stars" style="font-size:22px;">★★★★★</div>
      </div>
      <div class="g-cards" set:html={testimonialsHTML(d)} />
    </div>
  </section>
  )}

  <!-- ACCREDITATIONS -->
  {flags.showAccreditations && (
  <section style="background:#fff;border-top:1px solid #ececea;border-bottom:1px solid #ececea;">
    <div class="wrap" style="padding-top:clamp(40px,5vw,56px);padding-bottom:clamp(40px,5vw,56px);">
      <div style="text-align:center;font-family:'Montserrat',sans-serif;font-weight:700;font-size:12px;letter-spacing:2.5px;color:#79828f;text-transform:uppercase;margin-bottom:28px;">Accredited &amp; Trusted By</div>
      <div class="g-acc reveal" set:html={accHTML(d)} />
    </div>
  </section>
  )}

  <!-- AREAS WE COVER -->
  <section class="sec tex tex-grid" style="background:#f5f4f1;">
    <div class="wrap">
      <div class="reveal" style="text-align:center;max-width:700px;margin:0 auto clamp(30px,4vw,44px);">
        <span class="eyebrow" style="margin-bottom:16px;" data-sb="areasEyebrow">{p.areasEyebrow}</span>
        <h2 class="h2" style="margin-bottom:14px;" data-sb="areasHeading">{p.areasHeading}</h2>
        <p class="lead" data-sb="areasLead">{p.areasLead}</p>
      </div>
      <div class="reveal" style="display:flex;flex-wrap:wrap;gap:12px;justify-content:center;max-width:920px;margin:0 auto;">
        {areaChips.map((t) => <span class="area-chip">{t}</span>)}
      </div>
    </div>
  </section>

  <!-- LATEST FROM THE BLOG -->
  <section class="sec tex tex-dots" style="background:#fff;">
    <div class="wrap">
      <div class="reveal split" style="margin-bottom:clamp(36px,4vw,52px);align-items:flex-end;">
        <div>
          <span class="eyebrow" style="margin-bottom:16px;" data-sb="blogEyebrow">{p.blogEyebrow}</span>
          <h2 class="h2" data-sb="blogHeading">{p.blogHeading}</h2>
        </div>
        <a class="btn btn-go" href="/blog" style="padding:14px 24px;font-size:14px;">All Articles →</a>
      </div>
      <div class="g-cards" set:html={homeBlogHTML(d)} />
    </div>
  </section>

  <!-- FOLLOW ON FACEBOOK -->
  <section class="sec" style="background:#f5f4f1;">
    <div class="wrap reveal">
      <div class="fb-band">
        <div class="fb-band-ico"><svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M24 12.07C24 5.4 18.63 0 12 0S0 5.4 0 12.07c0 6.02 4.39 11.01 10.13 11.93v-8.44H7.08v-3.49h3.05V9.41c0-3.02 1.79-4.69 4.53-4.69 1.31 0 2.69.24 2.69.24v2.97h-1.52c-1.49 0-1.96.93-1.96 1.89v2.26h3.33l-.53 3.49h-2.8v8.44C19.61 23.08 24 18.09 24 12.07Z"/></svg></div>
        <div style="flex:1;">
          <h2 data-sb="fbHeading">{p.fbHeading}</h2>
          <p data-sb="fbText">{p.fbText}</p>
        </div>
        <a class="btn-fb" href={fbUrl} target="_blank" rel="noopener" data-sb="fbButton">{p.fbButton}</a>
      </div>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section style="position:relative;overflow:hidden;background:#12161d;">
    <div class="img-slot dark fill" style="opacity:0.22;"><img src={imgSrc(p.finalImage)} alt="" onload="this.parentNode.classList.add('has-img')" onerror="this.remove()"><span>Drop build site photo (optional)</span></div>
    <div class="wrap reveal" style="position:relative;text-align:center;padding-top:clamp(64px,8vw,104px);padding-bottom:clamp(64px,8vw,104px);max-width:820px;">
      <span class="eyebrow" style="color:#5cc6e8;margin-bottom:18px;" data-sb="finalEyebrow">{p.finalEyebrow}</span>
      <h2 class="h2" style="color:#fff;margin-bottom:16px;" data-sb="finalHeading">{p.finalHeading}</h2>
      <p class="lead" style="color:#aab3c0;margin:0 auto 14px;max-width:560px;" data-sb="finalLead">{p.finalLead}</p>
      <div style="display:flex;gap:14px;flex-wrap:wrap;justify-content:center;margin-top:24px;">
        <a class="btn btn-cy" href="/contact" data-sb="finalCta">{p.finalCta}</a>
        <a class="btn btn-gl" href={d.phoneHref} data-sb="finalCall">{p.finalCall}</a>
      </div>
    </div>
  </section>
</Base>
