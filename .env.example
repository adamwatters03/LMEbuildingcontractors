# ----- Storyblok (content) -----
# Add these in Vercel: Project → Settings → Environment Variables.
# Without them the site builds from the local defaults in src/lib/content.js.

# Content Delivery token (Storyblok → Settings → Access Tokens).
# Use the "Public" token for production, or the "Preview" token for a draft/preview deploy.
STORYBLOK_TOKEN=

# Space region: eu (default) | us | ap | ca
STORYBLOK_REGION=eu

# published (default) | draft  — use draft only on a preview deployment
STORYBLOK_VERSION=published
